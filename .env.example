# Скопируйте в .env для локальной разработки или задайте в EAS Secrets / eas.json → build.production.env
# Документация: https://docs.expo.dev/build-reference/variables/

# Обязательно для production: HTTPS URL API SyncFlow
EXPO_PUBLIC_API_BASE_URL=https://your-api.example.com/api

# Ресторан на мульти-тенант стенде (заголовок X-Restaurant-ID)
EXPO_PUBLIC_RESTAURANT_ID=restaurant1

# syncflow | local
EXPO_PUBLIC_INTEGRATED_BACKEND=syncflow

# Только для разработки — в production всегда false
EXPO_PUBLIC_USE_MOCK_API=false

# Только для staging с HTTP/IP (не использовать в публичном store-release)
# EXPO_PUBLIC_ALLOW_INSECURE_API=true
